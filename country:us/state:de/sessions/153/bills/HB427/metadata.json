{
  "legislative_session": "153",
  "identifier": "HB 427",
  "title": "AN ACT TO AMEND TITLE 11 OF THE DELAWARE CODE RELATING TO OFFENSES INVOLVING DEADLY WEAPONS AND DANGEROUS INSTRUMENTS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This substitute bill allows target practicing with a BB gun, projectile weapon, or firearm by a 16 or 17 year old without direct supervision of a person age 21 or above provided the 16 or 17 year old has permission of a parent or guardian and the 16 or 17 year old has completed a hunter education course.\r\nAdditionally, a 16 or 17 year old is allowed to hunt without direct supervision if they are in possession of a valid Delaware hunting license."
    }
  ],

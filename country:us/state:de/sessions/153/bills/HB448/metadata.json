{
  "legislative_session": "153",
  "identifier": "HB 448",
  "title": "AN ACT TO AMEND TITLE 15 OF THE DELAWARE CODE RELATING TO CAMPAIGN EXPENDITURES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act makes security expenses an authorized campaign expenditure.   The security expenses must be: (1) related to ensuring the safety of the candidate; and (2) associated with the candidate\u2019s activities, duties, or status as a candidate or elected official. Security expenses include home or office electronic security systems, personal security, and other security-related equipment or devices for a candidate.  Security expenses may not be used to purchase firearms.\r\nThis Act requires that the Commissioner promulgate rules to implement this Act within 3 months."
    }
  ],

  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act makes a technical correction to the specific persons who can access a fingerprint-based background check under this chapter in order to comply with the requirements of Public Law (Pub. L.) 92-544 for access to FBI criminal history record information."

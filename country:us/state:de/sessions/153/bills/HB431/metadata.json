  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act allows for the composting of yard waste, food residuals, and other organic materials on property zoned for agricultural purposes. County governments may limit the square footage allowed for this activity, but must allow for at least 5000 square feet per 4 acres of property."
    }
  ],

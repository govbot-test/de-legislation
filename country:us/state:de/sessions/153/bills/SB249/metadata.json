{
  "legislative_session": "153",
  "identifier": "SB 249",
  "title": "AN ACT TO AMEND TITLE 16 AND TITLE 29 OF THE DELAWARE CODE RELATING TO SUBSTANCE USE HARM REDUCTION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act does all of the following:\r\n(1) Establishes a regulatory framework for substance use harm reduction programs that provides immunities for program providers and staff. \r\n(2) Modifies the definition of drug paraphernalia.\r\n(3) Decriminalizes possession of paraphernalia for individuals who use drugs, while retaining prohibitions for paraphernalia used in the manufacturing or distribution of drugs and the selling of certain drug paraphernalia.\r\n\r\nThis Act also makes technical corrections to conform existing law to the standards of the Delaware Legislative Drafting Manual."
    }
  ],

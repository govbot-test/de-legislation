{
  "legislative_session": "153",
  "identifier": "SB 338",
  "title": "AN ACT TO AMEND TITLE 9 AND TITLE 22 OF THE DELAWARE CODE RELATING TO TELECOM INFRASTRUCTURE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act removes the cap on the amount of tax a county or municipality can levy on poles, wires, cable and conduit for distribution of telephone communication services.\r\n\r\nThis Act requires a greater than majority vote for passage because \u00a7 1 of Article IX of the Delaware Constitution requires the affirmative vote of two-thirds of the members elected to each house of the General Assembly to amend a municipal charter, whether directly, by amendment to a specific municipality's charter, or, as in this Act, indirectly, by a general law."
    }
  ],
  "other_titles": [

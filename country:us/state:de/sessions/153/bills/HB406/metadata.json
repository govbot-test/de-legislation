  "legislative_session": "153",
  "identifier": "HB 406",
  "title": "AN ACT TO AMEND TITLE 18 OF THE DELAWARE CODE RELATING TO UNFAIR TRADE PRACTICES IN AUTOMOBILE INSURANCE.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [

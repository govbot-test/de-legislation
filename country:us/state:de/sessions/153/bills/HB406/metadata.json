  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act updates auto insurance protections by prohibiting carriers from limiting repair or replacement work to particular facilities, individuals, or business establishments as a condition of payment of a claim. \r\nThis Act makes technical corrections to conform the statute with the Delaware Legislative Drafting Manual."
    }
  ],

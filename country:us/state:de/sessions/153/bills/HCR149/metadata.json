  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This resolution designates June 12, 2026, as \u201cLoving Day\u201d in the State of Delaware and reaffirms a commitment to the principles of equality, freedom, and justice for all. \u201cLoving Day\u201d contributes to building a society that values and respects the fundamental human rights of all individuals, regardless of their race or ethnicity."
    }
  ],

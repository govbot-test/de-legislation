{
  "legislative_session": "153",
  "identifier": "HCR 137",
  "title": "REQUIRING THE DEPARTMENT OF EDUCATION TO REVIEW AND REPORT ON DELAWARE MATHEMATICS INSTRUCTION AND MULTI-TIERED SYSTEM OF SUPPORT.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This House Concurrent Resolution requires the Delaware Department of Education to review the State's current MTSS framework in coordination with the DE Mathematics Framework as it relates to elementary, middle, and high school mathematics within academic and non-academic supports to develop recommendations to strengthen instructional coherence in math, assessment, and the alignment of support across all tiers of instruction and report findings and recommendations for legislative and regulatory action by June 30, 2027."
    }
  ],

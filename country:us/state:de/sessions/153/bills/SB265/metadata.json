{
  "legislative_session": "153",
  "identifier": "SB 265",
  "title": "AN ACT TO AMEND TITLE 16 OF THE DELAWARE CODE RELATING TO LONG TERM CARE FACILITIES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act requires a long-term care facility to refund any deposit or minimum-stay-requirement charges to a resident or a resident\u2019s family if the resident dies prior to or within 60 days of entering the facility, if the individual is unable to enter the facility due to a change in the individual\u2019s medical condition or needs, or if the resident is discharged or transferred from the facility within the first 60 days."
    }
  ],
  "other_titles": [
    {
      "note": "short title",
      "title": "Long-Term Care Facility/Refund/Deposit/60 Days/Death"
    }
  ],

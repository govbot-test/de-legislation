  "legislative_session": "153",
  "identifier": "HB 417",
  "title": "AN ACT TO AMEND TITLE 30 OF THE DELAWARE CODE RELATING TO RESTAURANT RETAILER LICENSE REQUIREMENTS AND LICENSE FEES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"

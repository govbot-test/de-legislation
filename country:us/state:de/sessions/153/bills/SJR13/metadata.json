{
  "legislative_session": "153",
  "identifier": "SJR 13",
  "title": "DIRECTING THE DELAWARE JUDICIARY TO ESTABLISH A PILOT COURT DATE REMINDER PROGRAM AND TO STUDY AND REPORT ON THE FEASIBILITY OF EXPANDING THE PROGRAM STATEWIDE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "joint resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Senate Joint Resolution recognizes that missed court appearances create costs for the justice system and negative consequences for individuals, and that reminder notifications can reduce failure-to-appear rates. It directs the Delaware Judiciary to report on the cost, timeline, and requirements to build a court date reminder program for the Justice of the Peace Court and to expand it to the Court of Common Pleas, Family Court, and Superior Court and provides that DELJIS shall build the program if funding is appropriated."
    }
  ],
  "other_titles": [
    {
      "note": "short title",
      "title": "Judiciary/Report/Court Date Reminder Program"
    }
  ],

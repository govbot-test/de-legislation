{
  "legislative_session": "153",
  "identifier": "HB 328",
  "title": "AN ACT TO AMEND TITLE 29 OF THE DELAWARE CODE RELATING TO AGENCY REGULATIONS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act includes changes to align the editorial powers of the Registrar with the Delaware Code editors related to removing gendered language from regulations when the intended meaning is clear. \r\n\r\nThis Act revises the submission and publication schedule of the Register of Regulations to provide more consistent review and processing times to the Registrar, which will allow for more effective interaction with promulgating agencies and more efficient distribution of the Registrar's workload. \r\n\r\nThis Act also removes language requiring the antiquated practice of providing copies of the Register of Regulations to 2 state daily newspapers. The Register of Regulations will continue to be published online for the public and copies will be provided, upon request, to the public, law libraries and public libraries in this state, and the Director of the Division of Libraries.\r\n\r\nThis Act also makes technical corrections to conform existing law to the standards of the Delaware Legislative Drafting Manual."
    }
  ],

  "legislative_session": "153",
  "identifier": "HB 394",
  "title": "AN ACT TO AMEND TITLE 16 OF THE DELAWARE CODE RELATING TO THE PURCHASE AND SALE OF ENERGY DRINKS AND CAFFEINNATED SUPPLEMENTS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This House Substitute for House Bill No. 394 creates a process for which the Division of Public Health creates signage stating that energy drinks and caffeinated dietary supplements are not recommended for children, individuals sensitive to caffeine, pregnant women, or women who are nursing. Dealers of energy drinks and caffeinated dietary supplements are then required to display the sign in a publicly visible location next to the products."
    }
  ],
  "other_titles": [
    {
      "note": "short title",
      "title": "Energy Drinks/Caffeine/DPH Signage"
    }
  ],

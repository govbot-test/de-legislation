{
  "legislative_session": "153",
  "identifier": "SB 284",
  "title": "AN ACT TO AMEND TITLE 11 OF THE DELAWARE CODE RELATING TO PROTECTING FIRST RESPONDERS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act makes it a crime for any person to either cross a marked barrier established by a first responder, or, after receiving a warning not to approach from a first responder who is engaged in the lawful performance of a legal duty, to violate the warning and approach or remain within 25 feet of the first responder, with the intent to do any of the following:\r\n(1) Impede or interfere with the first responder\u2019s ability to perform the first responder\u2019s legal duty.\r\n(2) Threaten the first responder with physical injury, serious physical injury, or death.\r\n\r\nFor purposes of this Act, a first responder means a law-enforcement officer, volunteer or paid firefighter, emergency medical technician, paramedic, or fire police officer."
    }
  ],
  "other_titles": [
    {
      "note": "short title",
      "title": "Crime/Interference with First Responder/Class A Misdemeanor"
    }
  ],

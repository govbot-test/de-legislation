  "legislative_session": "153",
  "identifier": "HB 392",
  "title": "AN ACT TO AMEND TITLE 6 OF THE DELAWARE CODE RELATING TO NONPROFIT ORGANIZATIONS AND THE PROHIBITION OF PARTISAN POLITICAL ACTIVITIES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [

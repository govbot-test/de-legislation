  "legislative_session": "153",
  "identifier": "HB 260",
  "title": "AN ACT TO AMEND TITLE 16 OF THE DELAWARE CODE RELATING TO THE DELAWARE HEALTH CARE COMMISSION HEALTH CARE PROVIDER LOAN REPAYMENT PROGRAM.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [

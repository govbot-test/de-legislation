  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act adds optometrists as health care providers who are eligible for the Health Care Provider Loan Repayment Program and limits the number of health care loan provider repayment grants to 2 optometrists per year."
    }
  ],

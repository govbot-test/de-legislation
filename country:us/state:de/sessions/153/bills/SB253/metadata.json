  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act revises the parent notification requirements for school bullying policies by repealing the requirement that notification be made using a form generated by the Department of Justice (DOJ). This change conforms to DOJ\u2019s current practices and procedures related to involvement with student behavior issues.\r\n\r\nThis Act also makes technical corrections to conform existing law to the standards of the Delaware Legislative Drafting Manual."
    }
  ],

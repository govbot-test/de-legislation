  "legislative_session": "153",
  "identifier": "SB 253",
  "title": "AN ACT TO AMEND TITLE 14 OF THE DELAWARE CODE RELATING TO SCHOOL BULLYING.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [

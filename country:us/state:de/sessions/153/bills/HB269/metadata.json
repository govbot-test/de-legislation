  "identifier": "HB 269",
  "title": "AN ACT TO AMEND TITLE 26 OF THE DELAWARE CODE RELATING TO NET-METERING AND INTERCONNECTION RULES.",
  "from_organization": "~{\"classification\": \"lower\"}",

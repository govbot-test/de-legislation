{
  "legislative_session": "153",
  "identifier": "HB 430",
  "title": "AN ACT PROPOSING AN AMENDMENT TO ARTICLE V OF THE DELAWARE CONSTITUTION RELATING TO ELECTIONS AND VOTING.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act is the first leg of a constitutional amendment that would require that only natural persons be allowed to vote in any election in this State, and forbid corporations and other artificial entities from voting in such elections.\r\n\r\nThis Act requires a greater than majority vote for passage because \u00a7 1 of Article XVI of the Delaware Constitution requires the affirmative vote of two-thirds of the members elected to each house of the General Assembly to amend the Delaware Constitution. \r\n\r\nIn addition, as the first leg of a constitutional amendment, the next General Assembly must pass an act concurring with this Act for it to become part of the Delaware Constitution."
    }
  ],

{
  "legislative_session": "153",
  "identifier": "HB 418",
  "title": "AN ACT TO AMEND TITLE 11 OF THE DELAWARE CODE RELATING TO FIREARMS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act serves to clean up Delaware\u2019s ghost gun law to address issues raised in ongoing litigation. This Act primarily creates a clear path for individuals who legally possessed unserialized firearms prior to the law\u2019s enactment to come into compliance, either by having them serialized through a federally licensed dealer or rendering them permanently inoperable. This Act also clarifies definitions and aligns the law with federal serialization standards, while preserving the underlying prohibition on untraceable firearms."
    }
  ],
  "other_titles": [
    {
      "note": "short title",
      "title": "Ghost Gun Law/Updates"
    }
  ],

  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Resolution recognizes the pertinent work of social workers throughout Delaware and the entire country, encourages the creation and expansion of Social Work programs, and recognizes March 2026 as Social Work Month in the State of Delaware."
    }
  ],

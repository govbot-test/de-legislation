  "legislative_session": "153",
  "identifier": "SCR 178",
  "title": "RECOGNIZING MAY 5, 2026, AS \"ALPHA PHI ALPHA LEGISLATIVE DAY AT THE CAPITOL\" IN DELAWARE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Concurrent Resolution recognizes May 5, 2026, as \u201cAlpha Phi Alpha Legislative Day at the Capitol\u201d in Delaware. It honors Alpha Phi Alpha Fraternity, Incorporated as an organization that has provided a voice and a strong vision to the struggle of African Americans and people of color in the State of Delaware and around the world."
    }
  ],

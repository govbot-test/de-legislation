  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act updates the school building maintenance standards to require the facilities evaluation instrument be established through regulation by the Department of Education rather than just through guidance from the Department.  It also clarifies that the minimum standard of good repair facility category related to hazardous materials includes that of lead."
    }
  ],

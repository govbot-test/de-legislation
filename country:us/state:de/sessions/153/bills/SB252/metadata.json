{
  "legislative_session": "153",
  "identifier": "SB 252",
  "title": "AN ACT TO AMEND TITLE 24 OF THE DELAWARE CODE RELATING TO THE OFFER OF AN ULTRASOUND AND AUSCULTATION SERVICES BEFORE TERMINATING A PREGNANCY.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act requires a health-care practitioner to offer a patient ultrasound imaging and auscultation of fetal heart tone services before terminating a human pregnancy. The patient is free to choose not to view the ultrasound or listen to the auscultation of fetal heart tone.\r\n\r\nThis Act is known as \"The Woman's Right to Know Act.\u201d"
    }
  ],

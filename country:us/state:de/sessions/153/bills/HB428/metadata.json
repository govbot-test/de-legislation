  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This is the first leg of a constitutional amendment creating a \"Crossover Day\" deadline for each House of the General Assembly to send legislation over to the other House. The annual budget appropriation act, grants-in-aid act, bond and capital improvements act, and resolutions are excluded from this deadline. Currently 26 states, including Maryland, have crossover day deadlines for passing legislation between their two legislative chambers."
    }
  ],

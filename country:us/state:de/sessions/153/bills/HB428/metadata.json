{
  "legislative_session": "153",
  "identifier": "HB 428",
  "title": "AN ACT PROPOSING AN AMENDMENT TO ARTICLE II OF THE DELAWARE CONSTITUTION RELATING TO THE GENERAL ASSEMBLY.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"

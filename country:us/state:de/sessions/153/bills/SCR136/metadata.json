  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Senate Concurrent Resolution designates the month of February 2026, as \"Eating Disorders Awareness and Prevention Month\" in Delaware to raise awareness, promote early detection, and encourage access to effective treatment for eating disorders."
    }
  ],

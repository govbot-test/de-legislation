{
  "legislative_session": "153",
  "identifier": "SB 268",
  "title": "AN ACT TO AMEND TITLE 2, TITLE 9, TITLE 19, AND TITLE 30 OF THE DELAWARE CODE RELATING TO SUPPORT FOR FEDERAL WORKERS AFFECTED BY A GOVERNMENT SHUTDOWN.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act provides the following support for federal workers during a government shutdown:\r\n(1) In Section 1 of this Act, interest free loans to provide financial assistance.\r\n(2) In Section 2 of this Act, free transportation on public transit.\r\n(3) In Sections 3 through 6 of this Act, deferral of certain State, county, and school tax filings, payments, and collections."
    }
  ],

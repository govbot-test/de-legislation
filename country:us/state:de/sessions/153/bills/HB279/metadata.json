  "identifier": "HB 279",
  "title": "AN ACT TO AMEND TITLE 23 OF THE DELAWARE CODE RELATING TO THE DELAWARE MARINE EQUIPMENT RIGHT TO REPAIR ACT.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"

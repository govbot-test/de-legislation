  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Concurrent Resolution recognizes April 19-25, 2026, as \"Crime Victims' Rights Week\" in the State of Delaware. The following websites provide more information on Crime Victims' Rights Week and the resources available to victims and survivors of crime:\r\nDelaware Coalition Against Domestic Violence, at https://dcadv.org\r\nDelaware Victims' Rights Task Force, at https://delawarevictimservices.org"
    }
  ],

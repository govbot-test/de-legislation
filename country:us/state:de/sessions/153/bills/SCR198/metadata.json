{
  "legislative_session": "153",
  "identifier": "SCR 198",
  "title": "RECOGNIZING THE HISTORIC SIGNIFICANCE OF MOTHER AFRICAN UNION CHURCH AND EXPRESSING THE SUPPORT OF THE DELAWARE GENERAL ASSEMBLY FOR ITS CONGREGATION AND COMMUNITY FOLLOWING THE DEVASTATING FIRE OF MAY 17, 2026.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Concurrent Resolution recognizes the historic and cultural significance of Mother African Union Church in Wilmington, one of the oldest Black congregations in Delaware. This Resolution expresses the support and solidarity of the Delaware General Assembly for the congregation and surrounding community following the devastating fire of May 17, 2026."
    }
  ],

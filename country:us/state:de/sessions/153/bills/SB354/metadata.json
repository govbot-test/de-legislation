  "identifier": "SB 354",
  "title": "AN ACT TO AMEND TITLE 18 OF THE DELAWARE CODE RELATING TO INSURANCE AND FINANCIAL INTERMEDIARIES",
  "from_organization": "~{\"classification\": \"upper\"}",

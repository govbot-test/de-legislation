  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act prohibits the Department of Corrections from entering into contracts with any for-profit entity for the use of inmate labor. \r\nThis Act does not apply to \u00a7 6533 of Title 11 relating to outside employment and work release."
    }
  ],

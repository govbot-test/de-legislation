  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This bill allows auction houses that are licensed by the Delaware Office of the Alcoholic Beverage Control Commissioner to auction spirits, so long as the spirits being auctioned are not made available for sale in any licensed facility or store."
    }

  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Senate Concurrent Resolution recognizes and celebrates 125 years of service by Delaware Libraries, honors their longstanding commitment to literacy, innovation, and community engagement, and commends the dedicated librarians and advocates who support schools and communities across the State."
    }
  ],

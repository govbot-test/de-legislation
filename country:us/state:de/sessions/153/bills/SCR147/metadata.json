  "identifier": "SCR 147",
  "title": "RECOGNIZING THE 125TH ANNIVERSARY OF DELAWARE LIBRARIES AND THEIR SERVICE TO THE PEOPLE OF THE STATE OF DELAWARE.",
  "from_organization": "~{\"classification\": \"upper\"}",

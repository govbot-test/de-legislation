  "identifier": "HCR 128",
  "title": "DECLARING THAT MAY 17-23, 2026, IS \"CHILDREN'S RESEARCH WEEK\" AND RECOGNIZING AND HONORING THE SIGNIFICANT CONTRIBUTIONS OF NEMOURS CHILDREN\u2019S HEALTH DELAWARE VALLEY PEDIATRIC RESEARCH TO CHILDREN\u2019S HEALTH IN DELAWARE, THE REGION, AND THE NATION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This concurrent resolution declares that May 17-23, 2026, is \"Children's Research Week\" and recognizes and honors Nemours Children\u2019s Health Delaware Valley Pediatric Research for its outstanding contributions to improving children\u2019s health, advancing pediatric science, and strengthening the health and well-being of families in Delaware and beyond."
    }
  ],

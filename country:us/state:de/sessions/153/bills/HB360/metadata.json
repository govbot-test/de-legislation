{
  "legislative_session": "153",
  "identifier": "HB 360",
  "title": "AN ACT TO AMEND TITLE 15 OF THE DELAWARE CODE RELATING TO CAMPAIGN CONTRIBUTIONS AND EXPENDITURES AND REPORTING PERIODS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act requires political committees to submit quarterly campaign finance reports, as opposed to only annual reports.  It removes the requirement that a political committee submit a campaign finance report 30 days before an election, but retains the requirement that a report be filed 8 days before an election.  The law currently requires only an annual report, a report 30 days before an election, and  a report 8 days before an election."
    }
  ],
  "other_titles": [

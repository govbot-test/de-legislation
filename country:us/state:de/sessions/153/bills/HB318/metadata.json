  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act terminates the Delaware Health Resources Board by deleting in its entirety Chapter 93 of Title 16. \r\nThis Board does have a responsibility to require certain persons to perform and accept certain charity care under   \u00a7 9311.  This responsibility is transferred to the Secretary of the Department of Health and Social Services."
    }

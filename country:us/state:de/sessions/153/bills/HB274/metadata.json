{
  "legislative_session": "153",
  "identifier": "HB 274",
  "title": "AN ACT TO AMEND TITLE 30 OF THE DELAWARE CODE RELATING TO THE CHILD AND DEPENDENT CARE EXPENSE TAX CREDIT.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "Like House Bill No. 274, House Substitute for House Bill No. 274 increases the state child and dependent care expense tax credit from the current 50% match to a full 100% match with the federal child and dependent care expense tax credit. The substitute is different from House Bill No. 274 in that it makes this increase applicable to taxable years beginning on or after January 1, 2027.  \r\nThis Act also makes technical corrections to conform existing law to the standards of the Delaware Legislative Drafting Manual."
    }
  ],

  "identifier": "HJR 12",
  "title": "ESTABLISHING A TASK FORCE TO STUDY AND MODERNIZE DELAWARE\u2019S PROCUREMENT, GRANTMAKING, AND CONTRACTING PRACTICES WITH CONTRACTED SERVICE PROVIDERS.",
  "from_organization": "~{\"classification\": \"lower\"}",

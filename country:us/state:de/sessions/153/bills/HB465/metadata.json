{
  "legislative_session": "153",
  "identifier": "HB 465",
  "title": "AN ACT TO AMEND TITLE 11 OF THE DELAWARE CODE RELATING TO VIRTUAL CURRENCY.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act adds virtual currency to the money laundering definition in the criminal code and gives the State legal authority to attempt to return virtual currency for victims. It also provides that if money cannot be returned to the victims of the crime, or are outside of the United States, it should be disposed of per order of the Superior Court."
    }
  ],
  "other_titles": [
    {
      "note": "short title",
      "title": "Virtual Currency/Money Laundering Definition/Add"
    }

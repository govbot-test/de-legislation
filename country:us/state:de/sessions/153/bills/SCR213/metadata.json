  "identifier": "SCR 213",
  "title": "REAFFIRMING THE LONGSTANDING SISTERHOOD PARTNERSHIP BETWEEN DELAWARE AND TAIWAN.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [

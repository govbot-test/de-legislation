  "legislative_session": "153",
  "identifier": "HB 254",
  "title": "AN ACT TO AMEND TITLE 4 AND TITLE 29 OF THE DELAWARE CODE RELATING TO THE DEPARTMENT OF HUMAN RESOURCES.",
  "from_organization": "~{\"classification\": \"lower\"}",

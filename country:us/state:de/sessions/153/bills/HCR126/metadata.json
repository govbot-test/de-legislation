{
  "legislative_session": "153",
  "identifier": "HCR 126",
  "title": "RECOGNIZING APRIL 13\u201314, 2026, AS YOM HASHOAH, HOLOCAUST REMEMBRANCE DAY.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Concurrent Resolution recognizes sundown on April 13, 2026, through nightfall on April 14, 2026, as Yom HaShoah, Holocaust Remembrance Day. It honors the memory of the six million Jewish men, women, and children murdered by the Nazi regime and its collaborators during the Holocaust, recognizes the courage and resilience of Jewish survivors and those who resisted oppression, and urges all residents of Delaware to reflect on the lessons of the Holocaust and stand against Antisemitism, hatred, and intolerance in all forms."
    }
  ],

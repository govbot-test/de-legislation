{
  "legislative_session": "153",
  "identifier": "SB 294",
  "title": "AN ACT TO AMEND TITLE 31 OF THE DELAWARE CODE RELATING TO CHILD CARE ASSISTANCE FOR FULL-TIME POST-SECONDARY EDUCATION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act makes full-time students attending post-secondary education for an associate or baccalaureate degree eligible for child care assistance. \r\n\r\nThis Act also adds the name of this State's child care assistance program, \"Purchase of Care\" or \"POC\" to Chapter 5 of Title 31 and makes technical corrections to conform existing law to the standards of the Delaware Legislative Drafting Manual.\r\n\r\nThis Act is effective immediately because under \u00a7 10113 of Title 29, amendments that make existing regulations consistent with changes in basic law are exempt from the procedural requirements under the Administrative Procedures Act."
    }
  ],

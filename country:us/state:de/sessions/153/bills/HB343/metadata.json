{
  "legislative_session": "153",
  "identifier": "HB 343",
  "title": "AN ACT TO AMEND TITLE 13 OF THE DELAWARE CODE RELATING TO METHODS TO OBTAIN JURISDICTION OVER RESPONDENT IN FAMILY COURT AND THE DUTY TO SUPPORT.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act allows the Division of Child Support Services (DCSS) to serve a non-custodial parent\u2019s summons for family court hearings by any form of mail with proof of delivery, including using the United States Postal Service or other commercial delivery services such as Federal Express (FedEx) or United Parcel Service (UPS)."
    }
  ],

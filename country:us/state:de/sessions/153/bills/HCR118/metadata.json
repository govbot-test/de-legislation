  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Concurrent Resolution encourages the Department of Veterans Affairs (Department) to explore and make recommendations on the feasibility of establishing a veteran\u2019s cemetery in Kent County, Delaware, and to submit a report containing those recommendations no later than January 1, 2027."
    }
  ],

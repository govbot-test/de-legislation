  "identifier": "HCR 118",
  "title": "ENCOURAGING THE DEPARTMENT OF VETERANS AFFAIRS TO EXPLORE THE POSSIBILITY OF ESTABLISHING A VETERAN\u2019S CEMETERY IN KENT COUNTY, DELAWARE.",
  "from_organization": "~{\"classification\": \"lower\"}",

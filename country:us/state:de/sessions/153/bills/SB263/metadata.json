{
  "legislative_session": "153",
  "identifier": "SB 263",
  "title": "AN ACT TO AMEND TITLE 19 OF THE DELAWARE CODE RELATING TO LABOR.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act adds minor league baseball players to the existing exemptions from state minimum wage and recordkeeping standards. After minor league players formed a union in 2022, minor league players represented by the Major League Baseball Players Association (MLBPA) signed their first collective bargaining agreement with Major League Baseball (MLB) in 2023. This exemption actualizes that existing collective bargaining agreement between the players union and MLB."
    }
  ],

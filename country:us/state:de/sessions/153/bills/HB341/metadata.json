{
  "legislative_session": "153",
  "identifier": "HB 341",
  "title": "AN ACT TO AMEND TITLE 29 OF THE DELAWARE CODE RELATING TO CHILD SUPPORT.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act creates a presumption that parents are not liable for the care, maintenance, and support of children committed to DSCYF, or admitted to a service provided by DSCYF.  The Family Court may order child support payments only if child support will not pose a barrier to parent reunification."
    }
  ],

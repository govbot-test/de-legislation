  "legislative_session": "153",
  "identifier": "HB 379",
  "title": "AN ACT TO AMEND TITLE 14 OF THE DELAWARE CODE RELATING TO THE COMPREHENSIVE SCHOOL DISCIPLINE IMPROVEMENT PROGRAM.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [

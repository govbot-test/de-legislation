{
  "legislative_session": "153",
  "identifier": "SB 273",
  "title": "AN ACT TO AMEND TITLE 14 OF THE DELAWARE CODE RELATING TO SAFETY FEATURES IN NEW SCHOOL CONSTRUCTION OR MAJOR RENOVATIONS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act clarifies that security film is distinct from ballistic-resistant materials, and adds that school construction will satisfy the requirements of \u00a7 2306(b) if ballistic-resistant materials are used in the required locations.\r\nThis Act also makes technical corrections to conform existing law to the standards of the Delaware Legislative Drafting Manual."
    }
  ],

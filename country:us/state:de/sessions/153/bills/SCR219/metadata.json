{
  "legislative_session": "153",
  "identifier": "SCR 219",
  "title": "RECOGNIZING JUNE 19, 2026, AS \"JUNETEENTH NATIONAL INDEPENDENCE DAY\" IN THE STATE OF DELAWARE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Concurrent Resolution recognizes June 19, 2026, as \"Juneteenth National Independence Day\" in the State of Delaware, and encourages the people of Delaware to reflect upon the significance of this day and honor its legacy with appropriate activities and events."
    }
  ],

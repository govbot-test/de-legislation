{
  "legislative_session": "153",
  "identifier": "HB 12",
  "title": "AN ACT TO AMEND TITLE 14 OF THE DELAWARE CODE RELATING TO TEACHER ACADEMY SCHOLARSHIPS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act creates a scholarship for students who have completed a Delaware Teacher Academy and are enrolled in a Delaware Educator Preparation Program.  This scholarship supplements the Educator Support Scholarship and is intended to fill a $2500 funding gap for aspiring educators who are in their first year at an Educator Preparation Program. No more than 35 scholarships may be awarded.  The scholarship will be expanded based on interest and funding in subsequent school years and will continue as funding is available."
    }
  ],

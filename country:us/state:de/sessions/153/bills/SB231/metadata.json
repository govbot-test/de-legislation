{
  "legislative_session": "153",
  "identifier": "SB 231",
  "title": "AN ACT TO AMEND TITLE 14 OF THE DELAWARE CODE RELATING TO SCHOOL SOCIAL WORKERS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act provides that School Social Workers who have successfully passed the Association of Social Work Boards National Clinical Examination and hold a Licensed Clinical Social Worker License with a salary supplement. This Act also makes technical corrections to conform existing law to the standards of the Delaware Legislative Drafting Manual."
    }
  ],

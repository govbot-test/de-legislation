  "legislative_session": "153",
  "identifier": "HB 435",
  "title": "AN ACT TO AMEND TITLES 18, 29, AND 31 OF THE DELAWARE CODE RELATING TO CERTIFIED REGISTERED NURSE ANESTHETISTS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [

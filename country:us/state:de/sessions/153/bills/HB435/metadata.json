  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act prohibits individual, group, state employee, and Medicaid health plans from differentiating in the reimbursement rate of a health service based on whether the service was provided by a certified registered nurse anesthetist or by a physician."
    }
  ],

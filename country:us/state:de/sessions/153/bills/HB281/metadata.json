  "identifier": "HB 281",
  "title": "AN ACT TO AMEND TITLE 11 OF THE DELAWARE CODE RELATING TO CHILD ABUSE BY A PERSON IN A POSITION OF TRUST, AUTHORITY, OR SUPERVISION.",
  "from_organization": "~{\"classification\": \"lower\"}",

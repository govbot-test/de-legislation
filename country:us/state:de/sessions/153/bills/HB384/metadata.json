{
  "legislative_session": "153",
  "identifier": "HB 384",
  "title": "AN ACT TO AMEND TITLE 29 OF THE DELAWARE CODE RELATING TO OPEN-END CONTRACTING FOR HIGHWAY CONSTRUCTION AND RECONSTRUCTION.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act amends the Delaware Code to allow open-end contracts for highway construction or reconstruction for up to five (5) years.  This Act is intended to conform Delaware\u2019s procurement statutes to the time limits permitted for contracts by the Federal Highway Administration (FHWA) and still ensure that adequate security is maintained to cover all bids and ongoing work."
    }
  ],
  "other_titles": [
    {
      "note": "short title",
      "title": "Open-Ended Contracts/Allow/Five Years"
    }
  ],

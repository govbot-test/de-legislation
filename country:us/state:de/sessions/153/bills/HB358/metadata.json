  "legislative_session": "153",
  "identifier": "HB 358",
  "title": "AN ACT TO AMEND TITLE 14 OF THE DELAWARE CODE RELATING TO STUDENT ELOPEMENT FROM SCHOOL.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act provides guidelines for Delaware schools in addressing elopement of students. This Act requires schools to notify the eloping student\u2019s parent or guardian the same day as the elopement incident. All schools must develop policies and procedures to implement the requirements of this Act."
    }
  ],

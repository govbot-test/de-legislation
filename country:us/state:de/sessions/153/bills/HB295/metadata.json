{
  "legislative_session": "153",
  "identifier": "HB 295",
  "title": "AN ACT TO AMEND TITLES 21 AND 29 OF THE DELAWARE CODE RELATING TO A DESIGNATED PARKING SPACE FOR VETERANS AT STATE BUILDINGS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act provides that the Director of the Office of Management and Budget must designate 1 or more reserved parking spaces for a veteran at certain designated state buildings and facilities. It also prohibits stopping, standing, or parking in the veteran\u2019s space. \r\nViolations of this Act are exempted from the civil penalty for parking violations that exists in Title 21. \r\nThis Act takes effect 6 months after its enactment into law.   \r\nThis Act also makes technical corrections to conform existing law to the standards of the Delaware Legislative Drafting Manual."
    }
  ],

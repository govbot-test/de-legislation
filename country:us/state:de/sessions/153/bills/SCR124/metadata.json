  "identifier": "SCR 124",
  "title": "A RESOLUTION ADVANCING CIVILITY AND STRENGTHENING DISCOURSE IN THE DELAWARE GENERAL ASSEMBLY.",
  "from_organization": "~{\"classification\": \"upper\"}",

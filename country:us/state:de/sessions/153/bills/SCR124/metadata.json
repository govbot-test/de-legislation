  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This resolution affirms that members of the General Assembly are committed to civility in public discourse and that they will lead by example to actively cultivate a political culture in Delaware where collaboration, respect, and productive discourse can thrive."
    }

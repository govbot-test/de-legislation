{
  "legislative_session": "153",
  "identifier": "SB 276",
  "title": "AN ACT TO AMEND TITLE 26 OF THE DELAWARE CODE RELATING TO ELECTRIC UTILITIES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act amends Delaware law to provide that electric cooperatives are not required to provide electric supply service to large load electric users with a projected monthly demand of more than 50MW. Electric cooperatives remain obligated to provide supply service to all customers in its service territory using less than 50MW."
    }
  ],
  "other_titles": [
    {
      "note": "short title",
      "title": "Large Load Electric Users/Electric Cooperatives/Not Required"
    }
  ],

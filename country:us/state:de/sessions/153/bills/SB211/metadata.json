  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act increases the size of the Governor\u2019s Council on Agriculture from 7 to 9 members. The Act also requires that 1 member on the Council must be a livestock producer, and 1 member must be a farmer that is 40 years old or younger."
    }
  ],

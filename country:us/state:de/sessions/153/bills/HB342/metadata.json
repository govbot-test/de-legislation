  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "Current law prohibits persons subject to Family Court protective orders from purchasing or possessing deadly weapons, with some exceptions.  This Act extends this prohibition to individuals with out-of-state protective orders as well."
    }
  ],

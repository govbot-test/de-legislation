  "legislative_session": "153",
  "identifier": "HB 342",
  "title": "AN ACT TO AMEND TITLE 11 OF THE DELAWARE CODE RELATING TO THE POSSESSION AND PURCHASE OF DEADLY WEAPONS BY PERSONS PROHIBITED.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [

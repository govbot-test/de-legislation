  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Concurrent Resolution requests the Delaware Division of the Arts, in cooperation with the Division of Small Business, prepare for consideration by the 154th General Assembly a report detailing recommendations for developing an arts, cultural, or creative district program and submit the report to the 154th General Assembly not later than April 2, 2027."
    }
  ],

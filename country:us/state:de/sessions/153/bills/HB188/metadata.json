  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act allows Delaware voters who are not affiliated with a political party to vote in a political party's primary election.\r\nCurrently there are approximately 170,000 registered Delaware voters who are not affiliated with a political party.\r\nMembers of a political party are not allowed to crossover and vote in another political party's primary election"
    }
  ],

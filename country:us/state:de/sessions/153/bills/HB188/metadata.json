  "legislative_session": "153",
  "identifier": "HB 188",
  "title": "AN ACT TO AMEND TITLE 15 OF THE DELAWARE CODE RELATING TO PRIMARY ELECTIONS.",
  "from_organization": "~{\"classification\": \"lower\"}",

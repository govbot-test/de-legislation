{
  "legislative_session": "153",
  "identifier": "HB 262",
  "title": "AN ACT TO AMEND TITLE 14 OF THE DELAWARE CODE RELATING TO PAID LEAVE.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act clarifies that paid leave for the adoption of a child may begin at one of the following times: (1) when the child is placed for adoption with the employee; (2) when the employee initiates a petition for adoption; or (3) when the adoption process is completed."
    }
  ],

  "legislative_session": "153",
  "identifier": "HB 217",
  "title": "AN ACT TO AMEND TITLE 25 OF THE DELAWARE CODE RELATING TO KEY SURRENDER IN RESIDENTIAL LEASES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [

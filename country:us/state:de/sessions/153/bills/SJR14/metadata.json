{
  "legislative_session": "153",
  "identifier": "SJR 14",
  "title": "DIRECTING THE DEPARTMENT OF EDUCATION TO CONDUCT A STUDY AND REPORT ON WORKFORCE DATA RELATING TO PUBLIC EDUCATION SUPPORT PROFESSIONALS.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "joint resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Joint Resolution directs the Department of Education to compile and submit a comprehensive report regarding the workforce data and compensation of education support professionals for the most recent school year. The report must identify staffing levels, vacancies, average wages paid, and the number of employees earning below a $40 hourly wage threshold. The Department is further required to recommend pay scales that align with a minimum living wage and submit its findings to the General Assembly and relevant state offices by November 2, 2026."
    }
  ],

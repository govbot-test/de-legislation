{
  "legislative_session": "153",
  "identifier": "SB 185",
  "title": "AN ACT TO AMEND TITLE 4 OF THE DELAWARE CODE RELATING TO ALCOHOLIC LIQUORS SOLD FOR OFF-PREMISE CONSUMPTION.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act would allow valid on-premise license holders to sell 1 bottle of a private label spirit purchased from a Delaware licensed importer that is either limited availability or limited allocation. \r\n\r\nThe Act also corrects a typographical error and changes 2750 ML bottles of wine to 2 750 bottles of wine."
    }
  ],

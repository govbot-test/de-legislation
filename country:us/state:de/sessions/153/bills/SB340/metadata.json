  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act requires long-term care facilities to have insurance policies that provide a minimum of $1 million per claim/$3 million aggregate coverage each for general liability and professional liability. This Act takes effect 180 days after enactment."
    }
  ],

  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act excludes large energy use facilities from the definition of a qualified facility for purposes of determining eligibility for a tax credit or license fee reduction for the creation of employment and qualified investment in business facilities."
    }
  ],

{
  "legislative_session": "153",
  "identifier": "HB 348",
  "title": "AN ACT TO AMEND TITLE 29 OF THE DELAWARE CODE RELATING TO ELECTRIC VEHICLES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act updates the electric vehicle rebate program administered by the Department of Natural Resources and Environmental Control in light of changes to federal policies and market forces affecting electric vehicle deployment. The bill provides the Department with additional flexibility to set rebate amounts and improve programmatic offerings. The bill also allows enhanced rebates for an eventual program targeting lower income families."
    }
  ],

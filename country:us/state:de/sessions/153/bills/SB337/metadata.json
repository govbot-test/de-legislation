    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act provides supplementary appropriations to certain Grants-in-Aid recipients for Fiscal Year 2027.\r\nSection 1 \u2013 Government Units and Senior Centers $40,534,269\r\nSection 2 \u2013 One-Times and Community Agencies $42,346,157\r\nSection 3 \u2013 Fire Companies and Public Service Ambulance Companies $15,541,500\r\nSection 4 \u2013 Veterans Organizations $985,125\r\nGRAND TOTAL $99,407,051"
    }
  ],

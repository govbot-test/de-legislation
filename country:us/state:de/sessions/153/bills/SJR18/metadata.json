  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Joint Resolution designates August 31, 2026 as \"International Overdose Awareness Day\" in Delaware and requires the state flag to be flown at half-staff in observance and to honor those whose lives were taken too soon."
    }
  ],

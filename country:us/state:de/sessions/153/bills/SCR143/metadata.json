{
  "legislative_session": "153",
  "identifier": "SCR 143",
  "title": "ESTABLISHING THE BLOCKCHAIN AND DIGITAL INNOVATION TASK FORCE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Resolution establishes the Blockchain and Digital Innovation Task Force, established for the purpose of examining opportunities to maintain and enhance Delaware\u2019s position as a leader in blockchain and digital innovation, and identifying how to attract and retain businesses engaged in digital assets and related technologies, while developing appropriate consumer protections and regulatory clarity. \r\nThe Task Force is to prepare and deliver a final report to the General Assembly and the Governor concerning its findings and recommendations, if any, for maintaining Delaware\u2019s competitive position in business law and digital innovation, no later than July 1, 2027."
    }
  ],

  "identifier": "HB 155",
  "title": "AN ACT TO AMEND TITLE 29 OF THE DELAWARE CODE RELATING TO THE PUBLICATION OF STATE PUBLIC INTEGRITY COMMISSION REPORTS.",
  "from_organization": "~{\"classification\": \"lower\"}",

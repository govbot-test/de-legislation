{
  "legislative_session": "153",
  "identifier": "HB 191",
  "title": "AN ACT TO AMEND TITLE 24 OF THE DELAWARE CODE RELATING TO MEDICAL PROFESSIONALS, TITLES, AND NONHUMAN ENTITIES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act clarifies that a nonhuman entity, including an agent powered by AI, may not be licensed as a professional nurse, APRN, practical nurse, physician, or physician assistant.  It further clarifies that a nonhuman entity may not use any of the foregoing professional titles."
    }
  ],
  "other_titles": [
    {
      "note": "short title",
      "title": "Licensed Medical Professional/Nonhuman Entity/Prohibited"
    }
  ],

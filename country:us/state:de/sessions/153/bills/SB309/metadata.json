  "legislative_session": "153",
  "identifier": "SB 309",
  "title": "AN ACT TO AMEND TITLE 11 OF THE DELAWARE CODE RELATING TO WORK BY INMATES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act removes authority from the Department of Corrections to deduct pay from inmate accounts for a proportionate share of the costs of incarceration of inmates in the facility in which the inmate is housed. \r\nThis Act also makes technical corrections to conform existing law to the standards of the Delaware Legislative Drafting Manual."
    }
  ],

{
  "legislative_session": "153",
  "identifier": "HB 258",
  "title": "AN ACT TO AMEND TITLE 4 OF THE DELAWARE CODE RELATING TO LICENSES FOR SALE OF ALCOHOLIC BEVERAGES.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act allows any municipality with a population of 50,000 or more to establish by ordinance rules for the location of liquor stores that are more restrictive than state law, and requires the Alcoholic Beverage Control Commissioner to refuse a license for any new establishment that does not comply with those rules."
    }
  ],

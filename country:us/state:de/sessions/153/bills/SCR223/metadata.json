  "identifier": "SCR 223",
  "title": "REQUESTING THE DELAWARE INTERSCHOLASTIC ATHLETIC ASSOCIATION DEVELOP AND IMPLEMENT POLICIES AND PROCEDURES TO GRANT QUALIFIED MEDIA ORGANIZATIONS AND SCHOOL BASED PROGRAMS ACCESS TO BROADCAST DIAA-SANCTIONED PLAYOFF AND CHAMPIONSHIP GAMES.",
  "from_organization": "~{\"classification\": \"upper\"}",

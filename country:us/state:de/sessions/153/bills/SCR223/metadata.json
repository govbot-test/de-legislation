  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Concurrent Resolution supports the recommendations made in the final report from the Delaware Interscholastic Athletic Association task force by requesting the development and implementation of policies and procedures to grant qualified media organizations and school-based programs access to broadcast DIAA-sanctioned high school playoff and championship games."
    }
  ],

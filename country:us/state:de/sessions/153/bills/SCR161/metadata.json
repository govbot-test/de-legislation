  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Concurrent Resolution designates March 26, 2026, as \"Epilepsy Awareness Day\" in the State of Delaware and calls upon State agencies and the people of Delaware to undertake suitable efforts to increase epilepsy awareness."
    }

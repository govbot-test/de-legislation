{
  "legislative_session": "153",
  "identifier": "HB 267",
  "title": "AN ACT TO AMEND TITLE 14 OF THE DELAWARE CODE RELATING TO READING COMPETENCY.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act provides that each school district and charter school must report three times a year, instead of annually, to the Department of Education, the number and percentage of students, disaggregated by grade and by individual school, identified with a potential reading deficiency, including characteristics of dyslexia, pursuant to mandated literary screening, and the literacy intervention approaches being provided."
    }
  ],
  "other_titles": [
    {
      "note": "short title",
      "title": "Potential Reading Deficiency/Report/3 Times a Year"
    }
  ],

{
  "legislative_session": "153",
  "identifier": "SB 339",
  "title": "AN ACT TO AMEND TITLE 16 OF THE DELAWARE CODE RELATING TO ADVANCE HEALTH CARE DIRECTIVES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act makes a technical correction to the optional special powers form in the Uniform Health Care Decisions Act in Title 16. Currently, the existing language in the form implies any number of days can be written in to the advance directive when designating a maximum length of time for a mental health care related admission. However, under \u00a7 2518(e) of Title 16, an agent or default surrogate may not consent to voluntary admission of an individual to a facility for mental health treatment for longer than 72 hours. This Act removes the open-ended language in the form, so that a voluntary admission to a mental health facility by an agent may not exceed 72 hours."
    }
  ],

{
  "legislative_session": "153",
  "identifier": "SCR 134",
  "title": "RECOGNIZING THE THETA ZETA ZETA CHAPTER OF ZETA PHI BETA SORORITY, INCORPORATED FOR ITS OUTSTANDING COMMITMENT AND SERVICE TO THE DOVER COMMUNITY.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This resolution recognizes and commends the Theta Zeta Zeta Chapter of Zeta Phi Beta Sorority, Incorporated for its years of exemplary service to the Dover community, with a focus on educational equity, health advocacy, civic engagement, and empowering women and children. The Chapter\u2019s work reflects the sorority\u2019s historic legacy of scholarship, service, sisterhood, and finer womanhood."
    }
  ],

  "legislative_session": "153",
  "identifier": "SB 360",
  "title": "AN ACT TO AMEND TITLE 19 OF THE DELAWARE CODE RELATING TO THE FAMILY AND MEDICAL LEAVE INSURANCE PROGRAM.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act changes the eligibility for Delaware's Family and Medical Leave Insurance Program (\"Program\") by removing the requirement that an individual be employed for at least 12 months by an employer with respect to whom leave is requested. This change would make eligible for the Program individuals who meet the hours-of-service requirement in less than 12 months."
    }
  ],

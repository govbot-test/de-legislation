{
  "legislative_session": "153",
  "identifier": "SB 332",
  "title": "AN ACT TO AMEND TITLE 21 OF THE DELAWARE CODE RELATING TO SPECIAL VANITY LICENSE PLATES.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act clarifies that special vanity license plates, which in Delaware are personal property, may be transferred from one owner to another without violating a U.S. District Court injunction that bars Delaware from issuing any new special vanity license plates or recalling any that the Division of Motor Vehicles has already issued."
    }
  ],
  "other_titles": [
    {
      "note": "short title",
      "title": "Special License Plates/Transfer/One Owner"
    }
  ],

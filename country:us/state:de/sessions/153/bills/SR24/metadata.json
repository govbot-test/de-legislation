  "identifier": "SR 24",
  "title": "DESIGNATING JUNE 28, 2026, AS \u201cSTONEWALL UPRISING REMEMBRANCE DAY\u201d IN THE STATE OF DELAWARE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This resolution affirms the importance of recognizing the history, contributions, and resilience of LGBTQIA+ individuals and designates June 28, 2026, as \u201cStonewall Uprising Remembrance Day\u201d in the State of Delaware. It also recognizes the historical significance of the Stonewall uprising in advancing LGBTQIA+ civil rights and encourages continued efforts to ensure Delaware residents are informed about the importance of acceptance of, and equitable treatment for, LGBTQIA+ individuals, as well as the preservation and accurate interpretation of LGBTQIA+ history."
    }
  ],

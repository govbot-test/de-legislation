  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This concurrent resolution designates May 2026 as \"Lupus Awareness Month\" in the State of Delaware and encourages expanded efforts to keep Delaware residents properly informed about Lupus symptom recognition and treatment."
    }

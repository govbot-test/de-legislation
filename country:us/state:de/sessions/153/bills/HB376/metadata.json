{
  "legislative_session": "153",
  "identifier": "HB 376",
  "title": "AN ACT TO AMEND THE CHARTER OF THE TOWN OF MILLVILLE.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Substitute for House Bill No. 376 removes provisions in the existing Town of Millville Charter that have been preempted or otherwise regulated by State law and makes technical changes.  \r\nThe original Bill reorganizes the Town Charter\u2019s sections into corresponding articles, adds a preamble, and modernizes wording.  Also, the Bill removes sections related to a Town-only assessment process, given the Town\u2019s use of county assessments and adds a property tax cap of 3% of the total assessed value in the Town.  The municipal election process is amended to include an ultimate tie-breaking mechanism."
    }
  ],

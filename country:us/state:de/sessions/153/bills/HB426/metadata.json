{
  "legislative_session": "153",
  "identifier": "HB 426",
  "title": "AN ACT TO AMEND TITLE 30 OF THE DELAWARE CODE RELATING TO STATE AID TO MUNICIPALITIES FOR STREETS.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act removes the requirement that certain reports to the State Aid to Municipalities for Streets Program be notarized and printed and permits reports to be submitted by electronic submission with a unique identifier. This Act also requires that the annual report that is submitted to the State Treasurer also be submitted to the Department of Transporation."
    }
  ],

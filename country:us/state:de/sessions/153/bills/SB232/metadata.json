{
  "legislative_session": "153",
  "identifier": "SB 232",
  "title": "AN ACT TO AMEND TITLE 11 OF THE DELAWARE CODE RELATING TO CRIMINAL MISCHIEF.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "synopsis",
      "abstract": "This Act increases for the crime of criminal mischief to a class F felony when the person intentionally causes damage to an authorized emergency vehicle resulting in a pecuniary loss of $5,000 or more or in the authorized emergency vehicle becoming temporarily unable to be used to respond to an emergency.\r\n\r\nThis Act also makes technical corrections to conform existing law to the standards of the Delaware Legislative Drafting Manual."
    }
  ],

  "identifier": "SCR 176",
  "title": "RECOGNIZING APRIL 25TH, 2026, AS \"DIABETIC RETINOPATHY SCREENING DAY\" IN DELAWARE.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
